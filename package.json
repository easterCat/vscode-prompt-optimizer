{
  "name": "prompt-optimizer-easy",
  "displayName": "Prompt Alchemy",
  "description": "A lightweight VSCode extension for optimizing AI prompts using configurable LLM providers.",
  "version": "0.1.1",
  "publisher": "easy-tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/easterCat/vscode-prompt-optimizer.git"
  },
  "icon": "media/main-app.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prompt-optimizer-easy",
          "title": "Prompt Alchemy",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "prompt-optimizer-easy": [
        {
          "type": "webview",
          "id": "easyPromptOptimizer.sidebar",
          "name": "Prompt Alchemy"
        }
      ]
    },
    "commands": [
      {
        "command": "easyPromptOptimizer.sendSelection",
        "title": "Send to Prompt Alchemy",
        "icon": "media/icon.svg"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "easyPromptOptimizer.sendSelection",
          "group": "easyPromptOptimizer@1",
          "when": "editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {}
}
